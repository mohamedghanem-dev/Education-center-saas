{
  "name": "edu-crm",
  "version": "1.0.0",
  "description": "نظام إدارة سنتر الدروس المتكامل",
  "main": "electron.js",
  "author": "Edu CRM",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "build:win": "electron-builder --win --x64",
    "build:linux": "electron-builder --linux",
    "build:mac": "electron-builder --mac"
  },
  "devDependencies": {
    "electron": "^30.0.0",
    "electron-builder": "^24.0.0"
  },
  "build": {
    "appId": "com.edu.crm",
    "productName": "سنتر الدروس",
    "copyright": "Copyright © 2026",
    "directories": { "output": "dist" },
    "files": [
      "index.html",
      "electron.js",
      "preload.js",
      "manifest.json",
      "icon.ico",
      "icon-192.png",
      "icon-512.png"
    ],
    "win": {
      "target": [{ "target": "nsis", "arch": ["x64"] }],
      "icon": "icon.ico",
      "requestedExecutionLevel": "asInvoker"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerLanguages": ["ar"],
      "language": "1025"
    },
    "linux": { "target": "AppImage", "icon": "icon.ico", "category": "Office" },
    "mac": { "target": "dmg", "icon": "icon.ico" }
  }
}
